APP_NAME=AIRI Virtual Assistant Backend
DEBUG=True
# 可选，不填时默认使用 backend/data/app.db
# DATABASE_URL=

# LLM
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your_llm_api_key
LLM_MODEL_NAME=doubao-seed-2-0-mini-260215

# ElevenLabs TTS
ELEVENLABS_API_BASE=https://api.elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_LANGUAGE_CODE=
ELEVENLABS_TIMEOUT_SECONDS=60
ELEVENLABS_ENABLE_LOGGING=True
ELEVENLABS_OPTIMIZE_STREAMING_LATENCY=0
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.15
ELEVENLABS_SPEED=1.0
ELEVENLABS_USE_SPEAKER_BOOST=True
